 /**
- * There is no setImmediate in browser and setTimeout is slow.
- * This yields to the Promise/microtask scheduler queue, not to timers or the
- * full macrotask event loop.
+ * Yields a real macrotask via setTimeout(0) so the UI thread (React state
+ * updates, Reanimated repaints) can run between argon2 block batches.
+ * The original noble implementation was a no-op microtask yield, which never
+ * unblocked the paint loop on RN/Hermes.
  * @example
- * Yield to the next scheduler tick.
+ * Yield to the macrotask queue.
  * ```ts
  * await nextTick();
  * ```
  */
-export const nextTick = async () => { };
+export const nextTick = () => new Promise((resolve) => setTimeout(resolve, 0));
