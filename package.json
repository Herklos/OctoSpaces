{
  "private": true,
  "name": "octospaces",
  "packageManager": "pnpm@10.11.0",
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "publish:all": "pnpm -r publish --access public --no-git-checks --tag latest",
    "publish:all:alpha": "pnpm -r publish --access public --no-git-checks --tag alpha"
  }
}
