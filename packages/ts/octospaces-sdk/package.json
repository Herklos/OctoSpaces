{
  "name": "@drakkar.software/octospaces-sdk",
  "version": "0.29.0",
  "description": "Shared headless spaces core — identity, registry, objects, and sync plumbing.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
