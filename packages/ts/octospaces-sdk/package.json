    "hash-wasm": "^4.12.0"
  },
  "peerDependencies": {
    "@drakkar.software/starfish-client": ">=3.0.0-alpha.43",
    "@drakkar.software/starfish-identities": ">=3.0.0-alpha.43",
    "@drakkar.software/starfish-keyring": ">=3.0.0-alpha.43",
    "@drakkar.software/starfish-protocol": ">=3.0.0-alpha.43",
    "@drakkar.software/starfish-sharing": ">=3.0.0-alpha.43",
    "@drakkar.software/starfish-spaces": ">=3.0.0-alpha.43",
