{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "OctoSpaces base",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "ignoreDeprecations": "6.0"
  }
}
